# Supabase — get from https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook secret — from stripe listen --forward-to or Stripe dashboard
STRIPE_WEBHOOK_SECRET=
# Price ID for $75/mo KOL subscription product
STRIPE_KOL_PRICE_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend)
# Get from: https://resend.com
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=KOLVault <noreply@kolvault.io>

# Escrow encryption — AES-256-GCM key for encrypting Solana escrow private keys
# Must be a 64-character hex string (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ESCROW_ENCRYPTION_KEY=

# Helius — Solana on-chain data API
HELIUS_API_KEY=your-helius-api-key
# Get from: https://helius.dev

# Solana RPC
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Or use a dedicated RPC: https://rpc.helius.xyz, QuickNode, etc.
# Default falls back to public mainnet endpoint (rate-limited)
